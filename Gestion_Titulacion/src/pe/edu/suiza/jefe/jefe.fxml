<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@jefe.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.suiza.jefe.JefeController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="top-bar" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="btnSidebarToggle" mnemonicParsing="false" onAction="#toggleSidebar" style="-fx-font-family: 'Font Awesome 6 Free Solid';" styleClass="btn-toggle-sidebar" text="&#xf0c9;" />
            <VBox>
               <children>
                  <Label styleClass="top-bar-title" text="IESTP SUIZA - SISTEMA DE TITULACIÓN" />
                  <Label styleClass="top-bar-subtitle" text="Jefatura de Investigación y Administración" />
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="8.0" styleClass="user-badge">
               <children>
                  <Label style="-fx-font-family: 'Font Awesome 6 Free Solid'; -fx-text-fill: #1e3a8a; -fx-font-weight: bold; -fx-font-size: 15px;" text="&#xf007;" />
                  <Label fx:id="lblUsuarioLogueado" styleClass="user-badge-text" text="Jefe de Investigación y Administración" />
               </children>
            </HBox>
            <Button mnemonicParsing="false" onAction="#cerrarSesion" styleClass="btn-danger" text="Salir" />
         </children>
      </HBox>
   </top>
   
   <left>
      <VBox fx:id="sidebar" prefWidth="230.0" spacing="8.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="btnNavAprobacion" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarPanelAprobacion" styleClass="sidebar-btn, sidebar-btn-active" text="Aprobación Final" />
            <Button fx:id="btnNavUsuarios" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarPanelUsuarios" styleClass="sidebar-btn" text="Gestión de Usuarios TI" />
            <Button fx:id="btnNavCatalogos" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarPanelCatalogos" styleClass="sidebar-btn" text="Catálogos y Modalidades" />
            <Button fx:id="btnNavReportes" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarPanelReportes" styleClass="sidebar-btn" text="Reportes Oficiales" />
            <Button fx:id="btnNavPerfil" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarPanelPerfil" styleClass="sidebar-btn" text="Configuración de Cuenta" />
         </children>
      </VBox>
   </left>
   
   <center>
      <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;" BorderPane.alignment="CENTER">
         <content>
            <StackPane fx:id="contentArea">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <VBox fx:id="panelAprobacion" spacing="15.0" styleClass="content-card">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label styleClass="card-header-title" text="Aprobación Final para Titulación" />
                              <Region HBox.hgrow="ALWAYS" />
                              <TextField fx:id="txtBuscarProy" prefWidth="250.0" promptText="Buscar proyecto por código o título..." styleClass="text-field-form" />
                           </children>
                        </HBox>
                        <Label styleClass="section-desc" text="Lista de proyectos revisados por la coordinación que requieren el visto bueno final para sustentación:" />
                        <TableView fx:id="tbProyectosAprobacion" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colAproCod" prefWidth="110.0" text="Código" />
                            <TableColumn fx:id="colAproTit" prefWidth="300.0" text="Título del Proyecto" />
                              <TableColumn fx:id="colAproProg" prefWidth="180.0" text="Programa de Estudio" />
                              <TableColumn fx:id="colAproMod" prefWidth="140.0" text="Modalidad" />
                              <TableColumn fx:id="colAproEst" prefWidth="120.0" text="Estado Actual" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#rechazarProyecto" styleClass="btn-secondary" text="Devolver o Rechazar" />
                              <Button mnemonicParsing="false" onAction="#aprobarProyectoFinal" styleClass="btn-primary" text="Aprobar para Titulación" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <VBox fx:id="panelUsuarios" managed="false" spacing="15.0" styleClass="content-card" visible="false">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label styleClass="card-header-title" text="Gestión y Soporte de Usuarios Institucionales" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Button mnemonicParsing="false" onAction="#nuevoUsuario" styleClass="btn-primary" text="Nuevo Usuario" />
                           </children>
                        </HBox>
                        <TableView fx:id="tbUsuarios" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colUsuUser" prefWidth="130.0" text="Usuario" />
                            <TableColumn fx:id="colUsuNom" prefWidth="280.0" text="Nombre Completo" />
                              <TableColumn fx:id="colUsuRol" prefWidth="180.0" text="Rol Asignado" />
                              <TableColumn fx:id="colUsuPassClaro" prefWidth="140.0" text="Clave (Soporte TI)" />
                              <TableColumn fx:id="colUsuEst" prefWidth="100.0" text="Estado" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>

                  <VBox fx:id="panelCatalogos" managed="false" spacing="15.0" styleClass="content-card" visible="false">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label styleClass="card-header-title" text="Mantenimiento de Catálogos - Carreras y Modalidades" />
                              <Region HBox.hgrow="ALWAYS" />
                              <ComboBox fx:id="cbTipoCatalogo" prefWidth="250.0" promptText="Filtrar tipo de catálogo..." styleClass="combo-box-form" />
                              <Button mnemonicParsing="false" onAction="#nuevoCatalogo" styleClass="btn-primary" text="Nuevo ítem" />
                           </children>
                        </HBox>
                        <TableView fx:id="tbCatalogos" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colCatTipo" prefWidth="160.0" text="Tipo de Catálogo" />
                            <TableColumn fx:id="colCatCod" prefWidth="120.0" text="Código" />
                              <TableColumn fx:id="colCatNom" prefWidth="280.0" text="Nombre del ítem" />
                              <TableColumn fx:id="colCatDesc" prefWidth="250.0" text="Descripción" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>

                  <VBox fx:id="panelReportes" managed="false" spacing="15.0" styleClass="content-card" visible="false">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label styleClass="card-header-title" text="Módulo de Reportes Oficiales IESTP Suiza - Filtro Temporal" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Button mnemonicParsing="false" onAction="#exportarReporteInstitucional" styleClass="btn-primary" text="Exportar Reporte" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #f8fafc; -fx-padding: 15px; -fx-background-radius: 8px; -fx-border-color: #cbd5e1; -fx-border-radius: 8px;">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label styleClass="label-form" text="Filtro Temporal - Mínimo hace 1 mes y Máximo hasta hace 5 años:" />
                                    <ComboBox fx:id="cbRangoTiempo" onAction="#aplicarFiltroReporte" prefWidth="300.0" styleClass="combo-box-form" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label styleClass="label-form" text="Tipo de Consolidado:" />
                                    <ComboBox fx:id="cbTipoReporte" onAction="#aplicarFiltroReporte" prefWidth="240.0" styleClass="combo-box-form" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label styleClass="label-form" text="Fecha Desde - Personalizado:" />
                                    <DatePicker fx:id="dpFechaDesde" onAction="#aplicarFiltroReporte" prefWidth="130.0" styleClass="date-picker-form" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label styleClass="label-form" text="Fecha Hasta:" />
                                    <DatePicker fx:id="dpFechaHasta" onAction="#aplicarFiltroReporte" prefWidth="130.0" styleClass="date-picker-form" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <TableView fx:id="tbReportes" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colRepFecha" prefWidth="110.0" text="Fecha Registro" />
                            <TableColumn fx:id="colRepCod" prefWidth="110.0" text="Código" />
                              <TableColumn fx:id="colRepTit" prefWidth="320.0" text="Título del Proyecto" />
                              <TableColumn fx:id="colRepProg" prefWidth="180.0" text="Programa de Estudio" />
                              <TableColumn fx:id="colRepEst" prefWidth="120.0" text="Estado" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </StackPane>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
