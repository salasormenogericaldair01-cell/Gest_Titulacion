<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane stylesheets="@recuperar.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.suiza.recuperar.RecuperarController">
   <children>
      <VBox alignment="CENTER" maxWidth="450.0" spacing="15.0" styleClass="card">
         <children>
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label style="-fx-font-family: 'Font Awesome 6 Free Solid'; -fx-font-size: 24px; -fx-text-fill: #1e3a8a;" text="&#xf084;" />
                  <Label styleClass="title" text="Recuperación de Credenciales" />
               </children>
            </HBox>
            <Label styleClass="subtitle" text="Ingrese su nombre de usuario para generar un Ticket de Soporte TI institucional sin dependencia de correos externos." textAlignment="CENTER" />
            
            <VBox spacing="6.0">
               <children>
                  <Label styleClass="field-label" text="Usuario del Sistema:" />
                  <HBox styleClass="input-box">
                     <children>
                        <Label style="-fx-font-family: 'Font Awesome 6 Free Solid'; -fx-text-fill: #64748b; -fx-font-size: 16px;" text="&#xf007;" />
                        <TextField fx:id="txtUsuarioRecuperar" promptText="Ejemplo: secretaria o alumno_01" styleClass="text-field-custom" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
            <VBox fx:id="boxTicket" managed="false" spacing="8.0" styleClass="ticket-box" visible="false">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #065f46; -fx-font-size: 15px;" text="¡Ticket Generado con Éxito!" />
                  <Label fx:id="lblTicketGenerado" style="-fx-font-weight: bold; -fx-text-fill: #047857; -fx-font-size: 18px;" text="TICK-SUIZA-0000" />
                  <Label style="-fx-text-fill: #065f46; -fx-font-size: 12px;" text="Acérquese a Jefatura de Investigación o Soporte TI con este código para resetear su clave local." textAlignment="CENTER" wrapText="true" />
               </children>
            </VBox>
            
            <Label fx:id="lblMensaje" style="-fx-text-fill: #dc2626; -fx-font-weight: bold; -fx-font-size: 13px;" text="" />
            
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cerrarModal" styleClass="btn-secondary" text="Cerrar" />
                  <Button fx:id="btnGenerar" mnemonicParsing="false" onAction="#generarTicket" styleClass="btn-primary" text="Generar Ticket TI" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
