<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@coordinador.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.suiza.coordinador.CoordinadorController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="top-bar" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="btnSidebarToggle" mnemonicParsing="false" onAction="#toggleSidebar" style="-fx-font-family: 'Font Awesome 6 Free Solid';" styleClass="btn-toggle-sidebar" text="&#xf0c9;" />
            <VBox>
               <children>
                  <Label styleClass="top-bar-title" text="IESTP SUIZA - SISTEMA DE TITULACIÓN" />
                  <Label styleClass="top-bar-subtitle" text="Módulo de Coordinación Académica" />
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="8.0" styleClass="user-badge">
               <children>
                  <Label style="-fx-font-family: 'Font Awesome 6 Free Solid'; -fx-text-fill: #1e3a8a; -fx-font-weight: bold; -fx-font-size: 15px;" text="&#xf007;" />
                  <Label fx:id="lblUsuarioLogueado" styleClass="user-badge-text" text="Coordinación Académica" />
               </children>
            </HBox>
            <Button mnemonicParsing="false" onAction="#cerrarSesion" styleClass="btn-danger" text="Salir" />
         </children>
      </HBox>
   </top>
   
   <left>
      <VBox fx:id="sidebar" prefWidth="230.0" spacing="8.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="btnNavRevision" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarPanelRevision" styleClass="sidebar-btn, sidebar-btn-active" text="Revisión de Proyectos" />
            <Button fx:id="btnNavObservaciones" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarPanelObservaciones" styleClass="sidebar-btn" text="Historial Observaciones" />
            <Button fx:id="btnNavPerfil" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarPanelPerfil" styleClass="sidebar-btn" text="Mi Perfil / Clave" />
         </children>
      </VBox>
   </left>
   
   <center>
      <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;" BorderPane.alignment="CENTER">
         <content>
            <StackPane fx:id="contentArea">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <VBox fx:id="panelRevision" spacing="15.0" styleClass="content-card">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label styleClass="card-header-title" text="Evaluación y Calificación de Proyectos" />
                              <Region HBox.hgrow="ALWAYS" />
                              <TextField fx:id="txtBuscar" prefWidth="250.0" promptText="Buscar por código, título o estado..." styleClass="text-field-form" />
                           </children>
                        </HBox>
                        
                        <TableView fx:id="tbProyectos" prefHeight="280.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colCod" prefWidth="110.0" text="Código" />
                            <TableColumn fx:id="colTit" prefWidth="280.0" text="Título del Proyecto" />
                              <TableColumn fx:id="colProg" prefWidth="160.0" text="Programa" />
                              <TableColumn fx:id="colMod" prefWidth="140.0" text="Modalidad" />
                              <TableColumn fx:id="colEst" prefWidth="130.0" text="Estado Actual" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        
                        <VBox spacing="10.0" style="-fx-background-color: #f1f5f9; -fx-padding: 15px; -fx-background-radius: 8px;">
                           <children>
                              <Label styleClass="label-form" text="Registro de Observaciones Metodológicas / Calificación:" />
                              <HBox spacing="15.0">
                                 <children>
                                    <TextArea fx:id="txtObservacion" prefHeight="80.0" promptText="Detalle aquí las correcciones que deben realizar los estudiantes..." styleClass="text-area-form" wrapText="true" HBox.hgrow="ALWAYS" />
                                    <VBox alignment="CENTER_RIGHT" prefWidth="240.0" spacing="12.0">
                                       <children>
                                          <Label styleClass="label-form" text="Cambiar Estado:" />
                                          <ComboBox fx:id="cbEstadoRevision" maxWidth="1.7976931348623157E308" promptText="Seleccionar Estado..." styleClass="combo-box-form" />
                                          <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#guardarRevision" styleClass="btn-primary" text="Guardar Evaluación" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <VBox fx:id="panelObservaciones" managed="false" spacing="15.0" styleClass="content-card" visible="false">
                     <children>
                        <Label styleClass="card-header-title" text="Historial General de Observaciones Emitidas" />
                        <TableView fx:id="tbObservaciones" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colObsFecha" prefWidth="130.0" text="Fecha" />
                            <TableColumn fx:id="colObsProy" prefWidth="200.0" text="Proyecto" />
                              <TableColumn fx:id="colObsDesc" prefWidth="380.0" text="Descripción de la Observación" />
                              <TableColumn fx:id="colObsEst" prefWidth="120.0" text="Estado Subs." />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </StackPane>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
